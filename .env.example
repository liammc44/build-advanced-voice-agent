# Copy this file to .env and fill in your three keys.

# AssemblyAI — real-time speech-to-text (Universal-3.5 Pro)
# Get one at https://www.assemblyai.com/dashboard/signup?utm_source=newsletter&utm_medium=influencer&utm_campaign=loop&utm_content=u35_realtime
ASSEMBLYAI_API_KEY=your_key_here

# Anthropic — Claude, the coach's brain
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Cartesia — text-to-speech voice
# Get one at https://play.cartesia.ai/keys
CARTESIA_API_KEY=your_key_here
